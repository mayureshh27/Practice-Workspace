#!/usr/bin/env bash
# Pre-push hook — runs the full test gate before pushing. This is the
# "feedback loop" the AI coding agents rely on.
#
# NOTE: typecheck, ruff, and mypy are currently ADVISORY (|| true) because
# Phase 0 surfaced 27 TS errors + 18 ruff errors + 38 mypy errors that
# the reviews already flagged. They are scheduled for fix in:
#   - Phase 12 (frontend type contracts — fixes TS errors)
#   - Phase 14 (housekeeping — fixes ruff/mypy errors)
#   Phase 0 leaves the gate advisory so the loop is installed and the
#   errors are visible, without blocking pushes during the fix cycle.
#   When all 15 phases land, this advisory goes away.
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "==> frontend typecheck (advisory) + test"
cd "$REPO_ROOT/frontend"
pnpm typecheck || echo "    typecheck errors are known; see docs/reviews/review.md R-1.3/R-3.1 (fix in Phase 12)"
pnpm test

echo "==> backend ruff (advisory) + mypy (advisory) + pytest (strict)"
cd "$REPO_ROOT/backend"
uv run ruff check . || echo "    ruff errors are known; see docs/reviews/code-review-by-layer.md (fix in Phase 14)"
uv run mypy app/ || echo "    mypy errors are known; see docs/reviews/code-review-by-layer.md (fix in Phase 14)"
uv run pytest --cov=app --cov-fail-under=55 --ignore=tests/test_workspace_api.py

cd "$REPO_ROOT"
