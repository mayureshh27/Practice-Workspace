export const EVAL_GATE_SCHEMA = 'schema_validation' as const;
export const EVAL_GATE_SANDBOX = 'sandbox_execution' as const;
export const EVAL_GATE_SOURCE = 'source_grounding' as const;
export type EvalGate =
  | typeof EVAL_GATE_SCHEMA
  | typeof EVAL_GATE_SANDBOX
  | typeof EVAL_GATE_SOURCE;

export const ALL_EVAL_GATES: EvalGate[] = [
  EVAL_GATE_SCHEMA,
  EVAL_GATE_SANDBOX,
  EVAL_GATE_SOURCE,
];

/** Converts the legacy `evalGates: number` from the backend into the typed array. */
export function evalGatesFromCount(n: number): EvalGate[] {
  return ALL_EVAL_GATES.slice(0, Math.min(n, ALL_EVAL_GATES.length));
}
/** Converts the typed array back to the backend's count field. */
export function evalGatesToCount(gates: EvalGate[]): number {
  return gates.length;
}
